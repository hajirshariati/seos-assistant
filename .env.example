# SEoS Assistant — environment variables
# Copy this file to `.env` and fill in real values for local development.
# In production, set these on your hosting platform (Railway, Render, etc.).

# ---- Shopify ----
# From the Partner Dashboard → App → Configuration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated list. Must match shopify.app.toml [access_scopes].scopes
SCOPES=read_products,read_customers,read_orders,write_orders,read_metaobjects
# Public URL where this app is reachable (no trailing slash)
SHOPIFY_APP_URL=https://your-app.example.com
# Optional — only needed for non-myshopify.com custom shop domains
SHOP_CUSTOM_DOMAIN=

# ---- Database ----
# PostgreSQL connection string for Prisma (see prisma/schema.prisma)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Encryption ----
# Required. Used to encrypt at-rest secrets (Anthropic key, Klaviyo private
# key, Yotpo loyalty key, etc.). Must be a 32-byte (64 hex char) value.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this key invalidates all previously-encrypted secrets — merchants
# would need to re-enter their API keys in the admin.
ENCRYPTION_KEY=

# ---- Runtime ----
NODE_ENV=production
PORT=3000
